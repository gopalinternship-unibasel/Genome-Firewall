# Serialized ModelRegistry directory: manifest.json + <safe-drug>.joblib files.
GENOME_FIREWALL_ARTIFACT_DIR=artifacts

# Live AMRFinderPlus is opt-in. The app remains usable with disclosed,
# precomputed annotations in demo mode.
GENOME_FIREWALL_ALLOW_LIVE_ANNOTATION=false
AMRFINDER_BIN=amrfinder
# Required for live inference. Point to a pinned database directory containing
# a version.txt/database_version.txt file; unverified databases fail closed.
AMRFINDER_DB=
AMRFINDER_ORGANISM=Escherichia
AMRFINDER_TIMEOUT_SECONDS=600

# Optional explanation layer. It consumes redacted enums and allowlisted IDs only;
# raw FASTA, sample IDs, and free-form evidence text must never be sent to OpenAI.
GENOME_FIREWALL_ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TIMEOUT_SECONDS=20

# Runtime safeguards.
GENOME_FIREWALL_MAX_UPLOAD_MB=20
